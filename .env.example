# Website LLM Analyzer - Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================================================
# LLM API KEYS - At least one provider required for audits
# ============================================================================

# Anthropic (Claude) - Recommended for most audits
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4) - Alternative provider
OPENAI_API_KEY=sk-proj-...

# Mistral AI - Cost-effective alternative
MISTRAL_API_KEY=...

# ============================================================================
# GEO VISIBILITY MONITOR - Needs at least one of these configured
# ============================================================================

# OpenAI API Key (for ChatGPT monitoring)
# OPENAI_API_KEY=sk-...

# Anthropic API Key (for Claude monitoring)
# ANTHROPIC_API_KEY=sk-ant-...

# Perplexity API Key (for Perplexity monitoring)
PERPLEXITY_API_KEY=pplx-...

# ============================================================================
# GOOGLE SEARCH CONSOLE OAUTH
# ============================================================================
# Create OAuth 2.0 credentials at https://console.cloud.google.com
# App type: Web Application | Enable: Search Console API
# Add authorized redirect URI: http://localhost:8000/api/gsc/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/gsc/oauth/callback

# Google Gemini — needed for Google provider in audits + GEO monitor
GEMINI_API_KEY=AIza...
# Alias used in some modules — set both to the same value
GOOGLE_GEMINI_API_KEY=AIza...

# ============================================================================
# KEYWORD RESEARCH (DataForSEO)
# ============================================================================
# Sign up at dataforseo.com — pay-per-use, ~$0.002 per keyword request
DATAFORSEO_LOGIN=your@email.com
DATAFORSEO_PASSWORD=your_dataforseo_password

# ============================================================================
# OPTIONAL FEATURES
# ============================================================================

# Authentication (Basic HTTP Auth) - Strongly recommended in production
# Leave empty to disable authentication entirely
AUTH_USERNAME=admin
AUTH_PASSWORD=change_me_strong_password

# Batch Processing (for large-scale audits)
ANTHROPIC_BATCH_API_KEY=

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Server configuration
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated list of allowed origins
# Add http://localhost:8000 for local development
ALLOWED_ORIGINS=https://app.nrankai.com

# Database (SQLite) - auto-created, no configuration needed
# DATABASE_PATH=api/data/analyzer.db

# ── nrankai.com Lead Audit Worker ──────────────────────────────────────────
# Set these to enable the lead audit worker that processes free audit form submissions
NRANKAI_CLOUD_URL=https://api.nrankai.com
NRANKAI_WORKER_KEY=your_worker_api_key_here
